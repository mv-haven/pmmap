# Server port
PORT=3001

# Vote threshold: a proposal auto-commits to the master map at this many upvotes.
# Set low (e.g. 2) for local testing.
VOTE_THRESHOLD=10

# Admin key. Enter this in the app's "Unlock admin" field to gain commit-now / dismiss powers.
# Change this to something private before deploying.
ADMIN_KEY=changeme-admin-key

# Postgres connection string. If UNSET, the server falls back to a local JSON file store
# (data/store.json) so it runs with zero setup. Render provides this automatically.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
